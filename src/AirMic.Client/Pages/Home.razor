@page "/"
@page "/{SecretKeyFromRoute}"
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@implements IDisposable

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-4">
    <MudGrid>
        <!-- Title and Logo -->
        <MudItem xs="12" Class="d-flex flex-column align-center justify-center text-center">
            <div class="glow-container @(IsStreaming ? "streaming-glow" : "")">
                <MudFab Color="@(IsStreaming ? Color.Success : Color.Primary)"
                        StartIcon="@(IsStreaming ? Icons.Material.Filled.Mic : Icons.Material.Filled.MicNone)"
                        Size="Size.Large"
                        Class="mic-pulse-button"
                        Disabled="false"/>
            </div>
            <MudText Typo="Typo.h4" Class="mt-4 font-weight-bold" Style="background: linear-gradient(135deg, #a855f7 0%, #3b82f6 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
                AirMic-Sink
            </MudText>
            <MudText Typo="Typo.body2" Style="color: rgba(255,255,255,0.45);">
                Low-Latency WebRTC Microphone Relay
            </MudText>
        </MudItem>

        <!-- Main Card -->
        <MudItem xs="12">
            <MudCard Elevation="4" Style="background-color: rgba(30, 30, 40, 0.6); backdrop-filter: blur(20px); border: 1px solid rgba(255,255,255,0.05); border-radius: 16px;">
                <MudCardContent Class="pa-5">
                    <MudGrid>
                        <!-- Form Fields -->
                        @if (!IsStreaming)
                        {
                            <MudItem xs="12">
                                <MudTextField @bind-Value="SignalingUrl"
                                              Label="Server URL"
                                              Variant="Variant.Outlined"
                                              Adornment="Adornment.Start"
                                              AdornmentIcon="@Icons.Material.Filled.SettingsInputHdmi"
                                              Disabled="IsConnecting || IsStreaming"
                                              Placeholder="wss://signaling.yourdomain.com/ws"/>
                            </MudItem>

                            <MudItem xs="12">
                                <MudTextField @bind-Value="StreamSecret"
                                              Label="Stream Key"
                                              Variant="Variant.Outlined"
                                              InputType="InputType.Password"
                                              Adornment="Adornment.Start"
                                              AdornmentIcon="@Icons.Material.Filled.Lock"
                                              Disabled="IsConnecting || IsStreaming"
                                              Placeholder="Enter Stream Secret Key"/>
                            </MudItem>

                            <MudItem xs="12">
                                <MudGrid Spacing="1" Class="align-center">
                                    <MudItem xs="10">
                                        <MudSelect T="string"
                                                   Label="Audio Input Device"
                                                   Variant="Variant.Outlined"
                                                   AnchorOrigin="Origin.BottomLeft"
                                                   TransformOrigin="Origin.TopLeft"
                                                   Adornment="Adornment.Start"
                                                   AdornmentIcon="@Icons.Material.Filled.Mic"
                                                   Value="SelectedDeviceId"
                                                   ValueChanged="OnSelectedDeviceChanged"
                                                   Disabled="IsConnecting || IsStreaming">
                                            @if (!AudioDevices.Any())
                                            {
                                                <MudSelectItem Value="@(string.Empty)">No audio devices found</MudSelectItem>
                                            }
                                            else
                                            {
                                                @foreach (var device in AudioDevices)
                                                {
                                                    <MudSelectItem Value="@device.DeviceId">@device.Label</MudSelectItem>
                                                }
                                            }
                                        </MudSelect>
                                    </MudItem>
                                    <MudItem xs="2" Class="d-flex align-center justify-center">
                                        <MudTooltip Text="Refresh devices">
                                            <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                                                           Color="Color.Primary"
                                                           OnClick="LoadAudioDevices"
                                                           Disabled="IsConnecting || IsStreaming"
                                                           Style="margin-top: 6px;"/>
                                        </MudTooltip>
                                    </MudItem>
                                </MudGrid>
                            </MudItem>

                            <MudItem xs="12" Class="mt-n5">
                                <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.35); display: block; margin-left: 12px; font-style: italic;">
                                    @GetSelectedDeviceLabel()
                                </MudText>
                            </MudItem>

                            <!-- Toggle Options -->
                            <MudItem xs="12" Class="mt-n5">
                                <MudDivider Style="background-color: rgba(255,255,255,0.05); margin: 8px 0;"/>
                                <MudSwitch @bind-Value="OptimizeForVoice"
                                           Color="Color.Primary"
                                           Label="Voice-Speech Optimized Mode"
                                           Disabled="IsConnecting || IsStreaming"/>
                                <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.35); display: block; margin-left: 58px;">
                                    <strong>Recommended</strong>: Standard setting for meetings. Keeps your voice sharp and stable while using very little network bandwidth. Turning this off bypasses speech processing to deliver unfiltered, crisp voice and high-fidelity stereo audio.
                                </MudText>
                            </MudItem>
                        }
                        else
                        {
                            <!-- Server URL Label when connected -->
                            <MudItem xs="12" Class="d-flex flex-column align-center justify-center text-center pt-4 mb-n3">
                                <div class="d-flex align-center justify-center mt-4 mb">
                                    <span class="connection-pulse mr-2"></span>
                                    <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.5); font-weight: 600; letter-spacing: 1.5px; text-transform: uppercase;">
                                        Connected Server
                                    </MudText>
                                </div>
                                <MudText Typo="Typo.body1" Class="font-weight-bold" Style="color: #3b82f6; white-space: nowrap; overflow-x: auto; display: block; max-width: 100%;">
                                    @SignalingUrl
                                </MudText>
                            </MudItem>
                        }

                        <!-- Error Message Alert -->
                        @if (!string.IsNullOrEmpty(ErrorMessage))
                        {
                            <MudItem xs="12">
                                <MudAlert Severity="Severity.Error" Variant="Variant.Filled" Dense="true" Class="rounded-lg">
                                    @ErrorMessage
                                </MudAlert>
                            </MudItem>
                        }

                        <!-- Action Buttons -->
                        <MudItem xs="12" Class="d-flex justify-center mt-4">
                            @if (!IsConnecting && !IsStreaming)
                            {
                                <MudButtonGroup Color="Color.Primary" Variant="Variant.Filled" Style="width: 100%; border-radius: 12px; height: 50px; background: linear-gradient(135deg, #a855f7 0%, #3b82f6 100%); overflow: hidden;">
                                    <MudButton id="start-stream-btn"
                                               Variant="Variant.Text"
                                               Size="Size.Large"
                                               FullWidth="true"
                                               StartIcon="@Icons.Material.Filled.PlayArrow"
                                               OnClick="() => StartConnection(false)"
                                               Style="border-radius: 12px 0 0 12px; height: 50px; flex-grow: 1; color: white;">
                                        Start Audio Stream
                                    </MudButton>
                                    <MudMenu Icon="@Icons.Material.Filled.ArrowDropDown"
                                             Style="align-self: auto; height: 50px;"
                                             Color="Color.Inherit"
                                             Dense="true"
                                             AnchorOrigin="Origin.BottomRight"
                                             TransformOrigin="Origin.TopRight">
                                        <MudMenuItem OnClick="() => StartConnection(true)">Test Loopback</MudMenuItem>
                                    </MudMenu>
                                </MudButtonGroup>
                            }
                            else
                            {
                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Error"
                                           Size="Size.Large"
                                           FullWidth="true"
                                           StartIcon="@Icons.Material.Filled.Stop"
                                           OnClick="StopConnection"
                                           Style="border-radius: 12px; height: 50px;">
                                    Stop @(IsTestMode ? "Test" : "Stream")
                                </MudButton>
                            }
                        </MudItem>
                    </MudGrid>
                </MudCardContent>
            </MudCard>
        </MudItem>

        <!-- Status Dashboard -->
        <MudItem xs="12">
            <MudCard Elevation="4" Style="background-color: rgba(20, 20, 25, 0.4); border: 1px solid rgba(255,255,255,0.03); border-radius: 16px;">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.subtitle1" Class="font-weight-bold" Color="Color.Primary">Connection Dashboard</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent Class="px-6 pb-6 pt-0">
                    <MudGrid Spacing="2">
                        <MudItem xs="6">
                            <MudText Typo="Typo.body2" Style="color: rgba(255,255,255,0.4);">Signaling Channel</MudText>
                            <MudChip T="string" Color="@GetSignalingColor()" Size="Size.Small" Variant="Variant.Text" Icon="@Icons.Material.Filled.Cable">
                                @SignalingState
                            </MudChip>
                        </MudItem>
                        <MudItem xs="6">
                            <MudText Typo="Typo.body2" Style="color: rgba(255,255,255,0.4);">WebRTC Peer</MudText>
                            <MudChip T="string" Color="@GetWebRtcColor()" Size="Size.Small" Variant="Variant.Text" Icon="@Icons.Material.Filled.Wifi">
                                @WebRtcState
                            </MudChip>
                        </MudItem>
                        <MudItem xs="6">
                            <MudText Typo="Typo.body2" Style="color: rgba(255,255,255,0.4);">Microphone Access</MudText>
                            <MudChip T="string" Color="@(IsMicCaptured ? Color.Success : Color.Default)" Size="Size.Small" Variant="Variant.Text" Icon="@Icons.Material.Filled.KeyboardVoice">
                                @(IsMicCaptured ? "Active" : "Inactive")
                            </MudChip>
                        </MudItem>
                        <MudItem xs="6">
                            <MudText Typo="Typo.body2" Style="color: rgba(255,255,255,0.4);">Remote Audio</MudText>
                            <MudChip T="string" Color="@(IsLoopbackActive ? Color.Success : (IsStreaming && IsTestMode ? Color.Info : Color.Default))" Size="Size.Small" Variant="Variant.Text" Icon="@Icons.Material.Filled.Hearing">
                                @(IsLoopbackActive ? "Receiving" : (IsStreaming && IsTestMode ? "Loopback Test" : "Offline"))
                            </MudChip>
                        </MudItem>
                    </MudGrid>
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>
    <MudGrid Class="justify-center mt-4 mb-2">
        <MudItem xs="12" Class="d-flex flex-column align-center justify-center text-center">
            <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.2);">
                AirMic-Sink v1.0.10 by Gabs
            </MudText>
            <MudText Typo="Typo.caption" Style="color: rgba(255,255,255,0.12); font-size: 0.75rem; margin-top: 2px;">
                Device: @(IsMobileDevice ? "Mobile" : "Desktop") | Wake Lock: @(WakeLockActive ? "Active" : "Inactive")
            </MudText>
        </MudItem>
    </MudGrid>
</MudContainer>

@if (ShowOledOverlay && WebRtcState == "connected")
{
    <div class="oled-overlay" @onclick="DismissOledOverlay">
        <div class="oled-overlay-content">
            <MudIcon Icon="@Icons.Material.Filled.Mic" Style="font-size: 3.5rem; color: rgba(239, 83, 80, 0.35); margin-bottom: 1rem;"/>
            <p class="oled-text">AirMic-Sink Active</p>
            <p class="oled-subtext">Tap anywhere to wake up screen</p>
        </div>
    </div>
}

<style>
    .glow-container {
        padding: 10px;
        border-radius: 50%;
        transition: all 0.5s ease-in-out;
    }

    .streaming-glow {
        box-shadow: 0 0 20px 5px rgba(46, 204, 113, 0.4);
        background-color: rgba(46, 204, 113, 0.05);
    }

    .mic-pulse-button {
        transform: scale(1.1);
        box-shadow: 0px 4px 15px rgba(0, 0, 0, 0.3);
    }

    .streaming-glow .mic-pulse-button {
        animation: pulse-animation 2s infinite;
    }

    @@keyframes pulse-animation {
        0% {
            transform: scale(1.1);
            box-shadow: 0 0 0 0 rgba(46, 204, 113, 0.6);
        }

        70% {
            transform: scale(1.15);
            box-shadow: 0 0 0 15px rgba(46, 204, 113, 0);
        }

        100% {
            transform: scale(1.1);
            box-shadow: 0 0 0 0 rgba(46, 204, 113, 0);
        }
    }

    .oled-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        background-color: rgba(0, 0, 0, 0.93);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        z-index: 9999;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        animation: oled-fade-in 0.3s ease-out;
    }

    .oled-overlay-content {
        text-align: center;
        user-select: none;
        animation: oled-pixel-shift 3000s steps(1) infinite;
    }

    @@keyframes oled-pixel-shift {
        0% {
            transform: translate(0, 0);
        }

        20% {
            transform: translate(12px, -15px);
        }

        40% {
            transform: translate(-15px, 10px);
        }

        60% {
            transform: translate(15px, 12px);
        }

        80% {
            transform: translate(-10px, -12px);
        }

        100% {
            transform: translate(0, 0);
        }
    }

    .oled-text {
        color: rgba(255, 255, 255, 0.25);
        font-size: 1.25rem;
        font-weight: 500;
        margin: 0;
    }

    .oled-subtext {
        color: rgba(255, 255, 255, 0.12);
        font-size: 0.85rem;
        margin-top: 4px;
        margin-bottom: 0;
    }

    @@keyframes oled-fade-in {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }

    .connection-pulse {
        width: 8px;
        height: 8px;
        background-color: #2ecc71;
        border-radius: 50%;
        display: inline-block;
        box-shadow: 0 0 0 0 rgba(46, 204, 113, 0.7);
        animation: pulse-green 2s infinite;
    }

    @@keyframes pulse-green {
        0% {
            transform: scale(0.95);
            box-shadow: 0 0 0 0 rgba(46, 204, 113, 0.7);
        }

        70% {
            transform: scale(1);
            box-shadow: 0 0 0 6px rgba(46, 204, 113, 0);
        }

        100% {
            transform: scale(0.95);
            box-shadow: 0 0 0 0 rgba(46, 204, 113, 0);
        }
    }
</style>

@code {
    [Parameter]
    public string? SecretKeyFromRoute { get; set; }

    private string SignalingUrl { get; set; } = "ws://localhost:8443/ws";
    private string StreamSecret { get; set; } = string.Empty;
    private bool OptimizeForVoice { get; set; } = true;

    private string SignalingState { get; set; } = "Disconnected";
    private string WebRtcState { get; set; } = "Offline";
    private bool IsMicCaptured { get; set; } = false;
    private bool IsLoopbackActive { get; set; } = false;

    private bool IsConnecting { get; set; } = false;
    private bool IsStreaming { get; set; } = false;
    private bool IsTestMode { get; set; } = false;
    private string? ErrorMessage { get; set; }
    private bool ShowOledOverlay { get; set; } = false;
    private bool IsMobileDevice { get; set; } = false;
    private bool WakeLockActive { get; set; } = false;

    private DotNetObjectReference<Home>? _selfReference;

    private List<AudioDevice> AudioDevices { get; set; } = new();
    private string SelectedDeviceId { get; set; } = string.Empty;

    private string GetSelectedDeviceLabel()
    {
        var device = AudioDevices.FirstOrDefault(d => d.DeviceId == SelectedDeviceId);
        return device != null ? device.Label : "No device selected";
    }

    protected override void OnInitialized()
    {
        _selfReference = DotNetObjectReference.Create(this);

        if (!string.IsNullOrEmpty(SecretKeyFromRoute))
        {
            StreamSecret = SecretKeyFromRoute;
        }

        // Pre-fill parameters from browser URL
        try
        {
            var uri = new Uri(NavigationManager.Uri);
            var query = System.Web.HttpUtility.ParseQueryString(uri.Query);

            var secretVal = query["secret"];
            if (!string.IsNullOrEmpty(secretVal))
            {
                StreamSecret = secretVal;
            }

            var signalingVal = query["signaling"];
            if (!string.IsNullOrEmpty(signalingVal))
            {
                SignalingUrl = signalingVal;
            }
            else
            {
                // Derive WebSocket URL directly from current browser hosting scheme, host, and port
                string wsScheme = uri.Scheme == "https" ? "wss" : "ws";
                SignalingUrl = $"{wsScheme}://{uri.Host}:{uri.Port}/ws";
            }
        }
        catch
        {
            // Fallback to defaults on parsing errors
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadAudioDevices();
            try
            {
                await JSRuntime.InvokeVoidAsync("airMic.initialize", _selfReference);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"[Client] Failed to register device change listener: {ex.Message}");
            }
        }
    }

    private async Task LoadAudioDevices()
    {
        try
        {
            var list = await JSRuntime.InvokeAsync<List<AudioDevice>>("airMic.getAudioDevices");
            if (list != null && list.Count > 0)
            {
                AudioDevices = list;
                if (string.IsNullOrEmpty(SelectedDeviceId) || !AudioDevices.Any(d => d.DeviceId == SelectedDeviceId))
                {
                    SelectedDeviceId = AudioDevices[0].DeviceId;
                }
            }
            else
            {
                AudioDevices = new List<AudioDevice>();
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Failed to load audio devices: {ex.Message}";
        }

        StateHasChanged();
    }

    private async Task OnSelectedDeviceChanged(string deviceId)
    {
        SelectedDeviceId = deviceId;
        if (IsStreaming)
        {
            try
            {
                await JSRuntime.InvokeVoidAsync("airMic.changeAudioDevice", SelectedDeviceId, OptimizeForVoice);
            }
            catch (Exception ex)
            {
                ErrorMessage = $"Failed to change audio device: {ex.Message}";
            }
        }
    }

    private async Task StartConnection(bool isTest = false)
    {
        ErrorMessage = null;
        if (string.IsNullOrWhiteSpace(StreamSecret))
        {
            ErrorMessage = "Stream Secret Key is required.";
            return;
        }

        if (!string.IsNullOrWhiteSpace(SignalingUrl))
        {
            string url = SignalingUrl.Trim();
            if (!url.StartsWith("ws://", StringComparison.OrdinalIgnoreCase) &&
                !url.StartsWith("wss://", StringComparison.OrdinalIgnoreCase))
            {
                url = "wss://" + url;
            }

            string cleanedUrl = url.TrimEnd('/');
            if (!cleanedUrl.EndsWith("/ws", StringComparison.OrdinalIgnoreCase))
            {
                cleanedUrl = cleanedUrl + "/ws";
            }

            SignalingUrl = cleanedUrl;
        }

        IsTestMode = isTest;
        IsConnecting = true;
        SignalingState = "Connecting...";

        try
        {
            await JSRuntime.InvokeVoidAsync(
                "airMic.startStreaming",
                SignalingUrl,
                StreamSecret,
                SelectedDeviceId,
                OptimizeForVoice,
                IsTestMode,
                _selfReference
            );
        }
        catch (Exception ex)
        {
            IsConnecting = false;
            SignalingState = "Disconnected";
            ErrorMessage = $"JSInterop initialization failed: {ex.Message}";
        }
    }

    private async Task StopConnection()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("airMic.stopStreaming");
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Failed to stop stream gracefully: {ex.Message}";
        }
    }

    [JSInvokable]
    public void OnDevicesChanged(List<AudioDevice> devices)
    {
        AudioDevices = devices ?? new List<AudioDevice>();
        if (!AudioDevices.Any(d => d.DeviceId == SelectedDeviceId))
        {
            SelectedDeviceId = AudioDevices.FirstOrDefault()?.DeviceId ?? string.Empty;
        }

        StateHasChanged();
    }

    [JSInvokable]
    public void OnMicCaptured(bool isCaptured)
    {
        IsMicCaptured = isCaptured;
        StateHasChanged();
    }

    [JSInvokable]
    public void OnSignalingStateChanged(string state)
    {
        SignalingState = state;
        if (state == "Connected")
        {
            IsConnecting = false;
            IsStreaming = true;
        }
        else if (state == "Disconnected")
        {
            IsConnecting = false;
            IsStreaming = false;
            IsMicCaptured = false;
            IsLoopbackActive = false;
            WebRtcState = "Offline";
            ShowOledOverlay = false;
            IsTestMode = false;
        }

        StateHasChanged();
    }

    [JSInvokable]
    public void OnWebRtcStateChanged(string state)
    {
        WebRtcState = state;
        StateHasChanged();
    }

    [JSInvokable]
    public void OnLoopbackAudioReceived(bool isReceived)
    {
        IsLoopbackActive = isReceived;
        StateHasChanged();
    }

    [JSInvokable]
    public void OnStreamStopped(bool stopped)
    {
        IsConnecting = false;
        IsStreaming = false;
        IsMicCaptured = false;
        IsLoopbackActive = false;
        SignalingState = "Disconnected";
        WebRtcState = "Offline";
        ShowOledOverlay = false;
        IsTestMode = false;
        StateHasChanged();
    }

    [JSInvokable]
    public void OnError(string errorMsg)
    {
        ErrorMessage = errorMsg;
        StateHasChanged();
    }

    [JSInvokable]
    public void SetOledOverlayVisible(bool visible)
    {
        ShowOledOverlay = visible;
        StateHasChanged();
    }

    [JSInvokable]
    public void SetDeviceStatus(bool isMobile)
    {
        IsMobileDevice = isMobile;
        StateHasChanged();
    }

    [JSInvokable]
    public void SetWakeLockStatus(bool active)
    {
        WakeLockActive = active;
        StateHasChanged();
    }

    private void DismissOledOverlay()
    {
        try
        {
            JSRuntime.InvokeVoidAsync("airMic.resetInactivityTimer");
        }
        catch
        {
        }

        ShowOledOverlay = false;
        StateHasChanged();
    }

    private void ActivateOledOverlay()
    {
        try
        {
            JSRuntime.InvokeVoidAsync("airMic.setOverlayVisible", true);
        }
        catch
        {
        }
    }

    private Color GetSignalingColor() => SignalingState switch
    {
        "Connected" => Color.Success,
        "Connecting..." => Color.Warning,
        _ => Color.Default
    };

    private Color GetWebRtcColor() => WebRtcState switch
    {
        "connected" => Color.Success,
        "connecting" => Color.Warning,
        "checking" => Color.Warning,
        "failed" => Color.Error,
        "closed" => Color.Default,
        _ => Color.Default
    };

    public void Dispose()
    {
        _selfReference?.Dispose();
    }

    public class AudioDevice
    {
        public string DeviceId { get; set; } = string.Empty;
        public string Label { get; set; } = string.Empty;
    }

}
