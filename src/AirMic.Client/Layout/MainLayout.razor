@inherits LayoutComponentBase

<MudThemeProvider IsDarkMode="true" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Color="Color.Inherit" Fixed="true" Elevation="1" Dense="true" Style="background-color: rgba(18, 18, 18, 0.85); backdrop-filter: blur(10px); border-bottom: 1px solid rgba(255, 255, 255, 0.05);">
        <MudIcon Icon="@Icons.Material.Filled.MicNone" Color="Color.Primary" Class="mr-2" />
        <MudText Typo="Typo.h6" Style="font-weight: 700; letter-spacing: 0.5px;">AirMic</MudText>
        <MudText Typo="Typo.caption" Class="ml-2 mt-1" Style="color: rgba(255, 255, 255, 0.45); font-weight: 500;">RELAY CLIENT</MudText>
        <MudSpacer />
        <MudIconButton Icon="@Icons.Custom.Brands.GitHub" Color="Color.Inherit" Href="https://github.com/hubert17/AirMic-Sink" Target="_blank" />
    </MudAppBar>
    <MudMainContent Class="pt-16 pa-6" Style="background: radial-gradient(circle at 10% 20%, rgba(18, 18, 26, 1) 0%, rgba(10, 10, 12, 1) 90%); min-height: 100vh; color: #e3e3e3;">
        @Body
    </MudMainContent>
</MudLayout>
